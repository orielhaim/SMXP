{
  "name": "smxp",
  "version": "0.0.1",
  "description": "Simple Message eXchange Protocol",
  "author": "orielhaim",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/orielhaim/smxp.git"
  },
  "module": "index.js",
  "type": "module",
  "scripts": {
    "lint": "biome check . --write",
    "start": "bun src/main.js",
    "cli": "bun scripts/cli.js",
    "node1": "PORT=3001 DB=./data/node1.db MESSAGES_DB=./data/node1-messages.db bun src/main.js",
    "node2": "PORT=3002 DB=./data/node2.db MESSAGES_DB=./data/node2-messages.db bun src/main.js",
    "send1to2": "PORT=3001 DB=./data/node1.db MESSAGES_DB=./data/node1-messages.db bun src/main.js send bob@test1.orielhaim.com alice@test2.orielhaim.com \"Hello from node1!\"",
    "send2to1": "PORT=3002 DB=./data/node2.db MESSAGES_DB=./data/node2-messages.db bun src/main.js send alice@test2.orielhaim.com bob@test1.orielhaim.com \"Hello from node2!\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/bun": "^1.3.14",
    "citty": "^0.2.2",
    "consola": "^3.4.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "@noble/post-quantum": "^0.6.1",
    "dns-packet": "^5.6.1",
    "elysia": "^1.4.28",
    "ky": "^2.0.2",
    "uuid": "^14.0.0"
  }
}
