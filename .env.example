HOST=0.0.0.0
PORT=7777
ADMIN_SECRET=your_secret_here

# Core (internal data)
CORE_DB=./data/core.db

# Messages
MESSAGES_DRIVER=local              # local | remote
MESSAGES_DB=./data/messages.db
# MESSAGES_URL=http://127.0.0.1:4000
# MESSAGES_TOKEN=

# Blobs (file attachments)
BLOBS_DRIVER=local                 # local | remote
BLOBS_DB=./data/blobs.db
BLOBS_ROOT=./data/blobs
BLOBS_MAX_SIZE=524288000           # 500MB

# Delivery
SMXP_RETRY_LIMIT=3
SMXP_RETRY_DELAY=1000
SMXP_RETRY_BACKOFF_LIMIT=10000
SMXP_TIMEOUT=10000
SMXP_TOTAL_TIMEOUT=30000

# DoH
SMXP_DOH_RETRY_LIMIT=2
SMXP_DOH_TIMEOUT=5000
