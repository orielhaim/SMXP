# Server
HOST=0.0.0.0
PORT=7777

# Database
DB=./data/smxp.db

# Message storage
# Built-in SQLite message store path. Used when MESSAGE_STORE_URL is not set.
MESSAGES_DB=./data/messages.db
# Optional external message store base URL.
# MESSAGE_STORE_URL=http://127.0.0.1:4000

# Generate one with: openssl rand -hex 32
ADMIN_SECRET=your_secret_here

# Delivery
SMXP_RETRY_LIMIT=3
SMXP_RETRY_DELAY=1000
SMXP_RETRY_BACKOFF_LIMIT=10000
SMXP_TIMEOUT=10000
SMXP_TOTAL_TIMEOUT=30000

# DOH
SMXP_DOH_RETRY_LIMIT=2
SMXP_DOH_TIMEOUT=5000
